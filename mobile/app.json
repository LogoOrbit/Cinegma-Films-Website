{
  "expo": {
    "name": "Cinegma Studio",
    "slug": "cinegma-studio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#070708"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#070708"
      },
      "package": "com.cinegma.studio"
    },
    "plugins": [
      "expo-secure-store",
      "expo-image-picker",
      "expo-document-picker"
    ],
    "newArchEnabled": false
  }
}
